{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "node",
		"ignoreDeprecations": "5.0",
		"outDir": "./dist",
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"types": ["node"]
	},
	"include": ["src/**/*", "prisma.config.ts"],
	"exclude": ["node_modules", "dist"]
}
