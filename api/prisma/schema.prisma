generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanAssinatura {
  FREE
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  EDITOR
}

enum UploadStatus {
  PENDING
  PROCESSING
  AWAITING_MAPPING
  DONE
  ERROR
}

model Tenant {
  id           String         @id @default(uuid())
  name         String         @map("nome_fantasia")
  cnpj         String         @unique
  plan         PlanAssinatura @default(FREE) @map("plano_assinatura")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  users        User[]
  branches     Branch[]
  sales        Sale[]
  rawUploads   RawUpload[]
  auditLogs    AuditLog[]
  dailyMetrics DailyMetrics[]
  anomalies    Anomaly[]

  @@map("tenants")
}

model User {
  id         String      @id @default(uuid())
  name       String      @map("nome")
  email      String
  password   String      @map("senha_hash")
  role       UserRole    @default(EDITOR)
  tenantId   String      @map("tenant_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rawUploads RawUpload[]
  auditLogs  AuditLog[]

  @@unique([email, tenantId])
  @@map("users")
}

model Branch {
  id           String         @id @default(uuid())
  name         String         @map("nome")
  city         String         @map("cidade")
  state        String         @map("estado")
  monthlyGoal  Decimal        @map("meta_mensal") @db.Decimal(15, 2)
  createdAt    DateTime       @default(now()) @map("created_at")
  tenantId     String         @map("tenant_id")
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales        Sale[]
  dailyMetrics DailyMetrics[]
  anomalies    Anomaly[]
  rawUploads   RawUpload[]

  @@map("branches")
}

model RawUpload {
  id               String       @id @default(uuid())
  filename         String       @map("nome_arquivo")
  originalName     String       @map("nome_arquivo_original")
  status           UploadStatus @default(PENDING)
  suggestedMapping Json?        @map("suggested_mapping")
  mapping          Json?
  errorMessage     String?      @map("error_message")
  branchId         String?      @map("branch_id")
  userId           String       @map("user_id")
  tenantId         String       @map("tenant_id")
  createdAt        DateTime     @default(now()) @map("data_upload")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@map("raw_uploads")
}

model Sale {
  id          String   @id @default(uuid())
  externalId  String   @map("external_id")
  saleDate    DateTime @map("data_venda")
  grossValue  Decimal  @map("valor_bruto") @db.Decimal(15, 2)
  totalCost   Decimal  @map("custo_total") @db.Decimal(15, 2)
  category    String?  @map("categoria")
  productName String   @map("produto_nome")
  quantity    Int      @map("quantidade")
  branchId    String   @map("branch_id")
  tenantId    String   @map("tenant_id")
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([externalId, tenantId])
  @@index([tenantId, saleDate])
  @@index([branchId, saleDate])
  @@index([productName])
  @@map("sales")
}

model DailyMetrics {
  id             String   @id @default(uuid())
  date           DateTime @map("data") @db.Date
  totalSales     Decimal  @map("total_vendas") @db.Decimal(15, 2)
  roiDay         Decimal  @map("roi_dia") @db.Decimal(10, 4)
  marginDay      Decimal  @map("margem_dia") @db.Decimal(10, 4)
  anomaliesCount Int      @default(0) @map("qtd_anomalias")
  branchId       String   @map("branch_id")
  tenantId       String   @map("tenant_id")
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([date, branchId])
  @@index([tenantId, date])
  @@index([branchId, date])
  @@map("daily_metrics")
}

model Anomaly {
  id         String   @id @default(uuid())
  saleDate   DateTime @map("sale_date")
  detectedAt DateTime @default(now()) @map("detected_at")
  deviation  Decimal  @map("desvio") @db.Decimal(8, 2)
  hypothesis String?  @map("hipotese")
  isCritical Boolean  @default(false) @map("is_critical")
  branchId   String   @map("branch_id")
  tenantId   String   @map("tenant_id")
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, detectedAt])
  @@index([tenantId, branchId])
  @@map("anomalies")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   @map("acao")
  timestamp DateTime @default(now())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, timestamp])
  @@map("audit_logs")
}
