generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanAssinatura {
  FREE
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  EDITOR
}

enum UploadStatus {
  PENDENTE
  PROCESSADO
  ERRO
}

model Tenant {
  id               String         @id @default(uuid())
  nome_fantasia    String
  cnpj             String         @unique
  plano_assinatura PlanAssinatura @default(FREE)
  created_at       DateTime       @default(now())

  users         User[]
  branches      Branch[]
  sales         Sale[]
  raw_uploads   RawUpload[]
  audit_logs    AuditLog[]
  daily_metrics DailyMetrics[]

  @@map("tenants")
}

model User {
  id         String   @id @default(uuid())
  nome       String
  email      String
  senha_hash String
  role       UserRole @default(EDITOR)
  tenant_id  String
  created_at DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  raw_uploads RawUpload[]
  audit_logs  AuditLog[]

  @@unique([email, tenant_id])
  @@map("users")
}

model Branch {
  id          String  @id @default(uuid())
  nome        String
  cidade      String
  estado      String
  meta_mensal Decimal @db.Decimal(15, 2)
  tenant_id   String

  tenant        Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sales         Sale[]
  daily_metrics DailyMetrics[]

  @@map("branches")
}

model RawUpload {
  id           String       @id @default(uuid())
  nome_arquivo String
  data_upload  DateTime     @default(now())
  status       UploadStatus @default(PENDENTE)
  user_id      String
  tenant_id    String

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("raw_uploads")
}

model Sale {
  id           String   @id @default(uuid())
  external_id  String
  data_venda   DateTime
  valor_bruto  Decimal  @db.Decimal(15, 2)
  custo_total  Decimal  @db.Decimal(15, 2)
  categoria    String
  produto_nome String
  quantidade   Int
  branch_id    String
  tenant_id    String

  branch Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([external_id, tenant_id])
  @@index([tenant_id, data_venda])
  @@index([branch_id, data_venda])
  @@map("sales")
}

model DailyMetrics {
  id            String   @id @default(uuid())
  data          DateTime @db.Date
  total_vendas  Decimal  @db.Decimal(15, 2)
  roi_dia       Decimal  @db.Decimal(10, 4)
  margem_dia    Decimal  @db.Decimal(10, 4)
  qtd_anomalias Int      @default(0)
  branch_id     String
  tenant_id     String

  branch Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([data, branch_id])
  @@index([tenant_id, data])
  @@map("daily_metrics")
}

model AuditLog {
  id        String   @id @default(uuid())
  user_id   String
  acao      String
  timestamp DateTime @default(now())
  tenant_id String

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, timestamp])
  @@map("audit_logs")
}